# Copy to staging.tfvars (do not commit staging.tfvars if it contains sensitive CIDRs).
# cp staging.tfvars.example staging.tfvars

aws_region        = "ap-southeast-1"
environment       = "staging"
github_repository = "trake25/Corp-Tower"

# Public key matching your GitHub secret EC2_STAGING_SSH_KEY (private half).
# Generate with: ssh-keygen -t ed25519 -C "corp-tower-staging" -f corp-tower-staging
# Or reuse the public key already on your legacy EC2 (~/.ssh/id_ed25519.pub or deploy key .pub).
ssh_public_key = "ssh-ed25519 AAAA... your-public-key ... comment"

# Restrict SSH to your IP for better security (find at https://ifconfig.me then use x.x.x.x/32).
ssh_cidr       = "0.0.0.0/0"
game_port_cidr = "0.0.0.0/0"
gateway_domain = "corp-tower.duckdns.org"

# Optional: pin all staging EC2 instances to one known-good subnet.
# staging_subnet_id = "subnet-..."

# Free-tier learning lab shape:
# - EC2-1 gateway simulates ALB/Redis with Caddy and Docker Redis.
# - EC2-2/EC2-3 run Docker server workers.
# Stop workers when not testing to control credits.
worker_count = 2
