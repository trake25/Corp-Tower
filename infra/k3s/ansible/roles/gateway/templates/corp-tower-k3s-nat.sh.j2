#!/usr/bin/env bash
set -euo pipefail

PRIVATE_CIDR="{{ private_subnet_cidr }}"
PUBLIC_IFACE="$(ip route show default | awk '{ print $5; exit }')"

sysctl -w net.ipv4.ip_forward=1
cat >/etc/sysctl.d/99-corp-tower-k3s-nat.conf <<SYSCTL
net.ipv4.ip_forward = 1
SYSCTL

iptables -t nat -C POSTROUTING -s "${PRIVATE_CIDR}" -o "${PUBLIC_IFACE}" -j MASQUERADE 2>/dev/null \
  || iptables -t nat -A POSTROUTING -s "${PRIVATE_CIDR}" -o "${PUBLIC_IFACE}" -j MASQUERADE

iptables -C FORWARD -s "${PRIVATE_CIDR}" -j ACCEPT 2>/dev/null \
  || iptables -A FORWARD -s "${PRIVATE_CIDR}" -j ACCEPT

iptables -C FORWARD -d "${PRIVATE_CIDR}" -m state --state RELATED,ESTABLISHED -j ACCEPT 2>/dev/null \
  || iptables -A FORWARD -d "${PRIVATE_CIDR}" -m state --state RELATED,ESTABLISHED -j ACCEPT
