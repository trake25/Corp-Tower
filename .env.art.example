# Corp Tower — private art asset pipeline (local development)
#
# Copy to .env.art and fill in. .env.art is gitignored and must never be committed.
#   cp .env.art.example .env.art
#
# These are the READ-WRITE developer credentials (R2 API token
# "corp-tower-art-dev", Object Read & Write, scoped to the single bucket).
# CI uses a SEPARATE read-only token stored in GitHub Secrets — do not reuse
# this one there. See docs/private-assets-setup.md.

# Cloudflare account ID (dashboard sidebar, or R2 overview page)
R2_ACCOUNT_ID=

# Credentials from the "corp-tower-art-dev" R2 API token
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=

# Bucket name — should not need changing
R2_BUCKET=corp-tower-assets
